#!/usr/bin/env python3

import argparse
import sys
from pathlib import Path

import xml.etree.ElementTree as ET

import yaml

import osc.conf
import osc.connection
import osc.core

# Root of the packaging tree, relative to this script
REPO_ROOT = Path(__file__).parent / "root"


def resolve_project_path(project: str) -> Path:
    """Convert OBS colon notation (prjA:prjB) to a filesystem path (root/prjA/prjB)."""
    return REPO_ROOT.joinpath(*project.split(":"))


def is_package(path: Path) -> bool:
    """A directory is a package if it contains an obs/ subdirectory or a package.yaml file."""
    return (path / "obs").is_dir() or (path / "package.yaml").exists()


def is_project(path: Path) -> bool:
    """A directory is a project if it contains a project.yaml file or is not a package."""
    return (path / "project.yaml").exists() or not is_package(path)


def find_packages(project_path: Path, obs_project: str):
    """Recursively yield (obs_project, package_path) for all packages under a directory.

    obs_project is the full OBS project name (e.g. 'home:Admin:ppg:17.9').
    Subdirectories that are themselves projects (no obs/) are treated as
    subprojects and descended into, extending obs_project with the child name.
    """
    for child in sorted(project_path.iterdir()):
        if not child.is_dir():
            continue
        if is_package(child):
            yield obs_project, child
        else:
            yield from find_packages(child, f"{obs_project}:{child.name}")


def load_yaml(path: Path) -> dict:
    """Load a YAML file and return its contents, or an empty dict if the file does not exist."""
    if not path.exists():
        return {}
    with path.open() as f:
        return yaml.safe_load(f) or {}


def build_project_meta(obs_project_name: str, title: str, description: str, repositories: list) -> str:
    """Build OBS project metadata XML from project.yaml fields."""
    root = ET.Element("project", name=obs_project_name)
    ET.SubElement(root, "title").text = title
    ET.SubElement(root, "description").text = description
    for repo in repositories:
        repo_elem = ET.SubElement(root, "repository", name=repo["name"])
        path_info = repo.get("path", {})
        if path_info:
            ET.SubElement(repo_elem, "path",
                          project=path_info["project"],
                          repository=path_info["repository"])
        for arch in repo.get("archs", []):
            ET.SubElement(repo_elem, "arch").text = arch
    ET.indent(root)
    return ET.tostring(root, encoding="unicode")


def build_package_meta(obs_project_name: str, package_name: str, title: str, description: str) -> str:
    """Build OBS package metadata XML from package.yaml fields."""
    root = ET.Element("package", name=package_name, project=obs_project_name)
    ET.SubElement(root, "title").text = title
    ET.SubElement(root, "description").text = description
    ET.indent(root)
    return ET.tostring(root, encoding="unicode")


def find_projects(path: Path, obs_project: str):
    """Recursively yield (obs_project_name, project_path) for project directories.

    obs_project_name is derived from the directory hierarchy unless overridden by
    the 'name' field in project.yaml. Only directories that are projects (no obs/)
    are descended into; package directories are skipped.
    """
    config = load_yaml(path / "project.yaml")
    obs_project_name = config.get("name") or obs_project
    yield obs_project_name, path
    for child in sorted(path.iterdir()):
        if child.is_dir() and is_project(child):
            yield from find_projects(child, f"{obs_project}:{child.name}")


def _apply_project_config(apiurl: str, obs_project_name: str, project_path: Path, force: bool = False) -> None:
    """Create or update OBS project metadata and build config from project.yaml."""
    project_config = load_yaml(project_path / "project.yaml")
    meta = build_project_meta(
        obs_project_name,
        project_config.get("title", ""),
        project_config.get("description", ""),
        project_config.get("repositories", []),
    )
    osc.core.edit_meta(
        metatype="prj",
        path_args=(obs_project_name,),
        data=[meta],
        force=force,
        apiurl=apiurl,
    )
    print(f"Updated project meta: {obs_project_name}")
    project_config_str = project_config.get("project-config") or ""
    osc.core.edit_meta(
        metatype="prjconf",
        path_args=(obs_project_name,),
        data=[project_config_str],
        force=force,
        apiurl=apiurl,
    )
    print(f"Updated project config: {obs_project_name}")


def _apply_package_config(apiurl: str, obs_project_name: str, package_name: str, package_path: Path, force: bool = False) -> None:
    """Create or update OBS package metadata from package.yaml."""
    package_config = load_yaml(package_path / "package.yaml")
    meta = build_package_meta(
        obs_project_name,
        package_name,
        package_config.get("title", ""),
        package_config.get("description", ""),
    )
    osc.core.edit_meta(
        metatype="pkg",
        path_args=(obs_project_name, package_name),
        data=[meta],
        force=force,
        apiurl=apiurl,
    )
    print(f"Updated package meta: {obs_project_name}/{package_name}")


def _upload_obs_files(apiurl: str, obs_project_name: str, package_name: str, obs_dir: Path) -> None:
    """Upload all files in obs_dir to the OBS package source."""
    for filepath in sorted(obs_dir.iterdir()):
        if not filepath.is_file():
            continue
        url = osc.core.makeurl(apiurl, ["source", obs_project_name, package_name, filepath.name])
        osc.connection.http_PUT(url, file=str(filepath))
        print(f"Uploaded {filepath.name} to {obs_project_name}/{package_name}")


def cmd_deploy(args):
    """Create or update the OBS project and/or package from local packaging files.

    Supported call forms:
      deploy                        — deploy everything under root/
      deploy <project>              — deploy all packages under a project
      deploy <top-level-package>    — deploy a single package with no project grouping
      deploy <project> <package>    — deploy a single package under a project
    """
    if args.project is None:
        # No args: deploy everything under root
        targets = list(find_packages(REPO_ROOT, args.rootprj))
        if not targets:
            print("error: no packages found under root", file=sys.stderr)
            sys.exit(1)
    else:
        first_path = resolve_project_path(args.project)
        if not first_path.is_dir():
            print(f"error: '{args.project}' not found under root/", file=sys.stderr)
            sys.exit(1)

        if is_package(first_path):
            # First arg is a top-level package, not a project
            if args.package is not None:
                print(f"error: '{args.project}' is a package; a sub-package argument cannot be given", file=sys.stderr)
                sys.exit(1)
            targets = [(args.rootprj, first_path)]
        else:
            # First arg is a project
            full_obs_project = f"{args.rootprj}:{args.project}"
            if args.package is not None:
                package_path = first_path / args.package
                if not package_path.is_dir():
                    print(f"error: package directory not found: {package_path}", file=sys.stderr)
                    sys.exit(1)
                if not is_package(package_path):
                    print(f"error: '{args.package}' is not a package (no obs/ directory found inside)", file=sys.stderr)
                    sys.exit(1)
                targets = [(full_obs_project, package_path)]
            else:
                targets = list(find_packages(first_path, full_obs_project))
                if not targets:
                    print(f"error: no packages found under project '{args.project}'", file=sys.stderr)
                    sys.exit(1)

    apiurl = osc.conf.config["apiurl"]
    seen_projects: set = set()

    for obs_project, package_path in targets:
        project_path = package_path.parent
        project_config = load_yaml(project_path / "project.yaml")
        obs_project_name = project_config.get("name") or obs_project

        if obs_project not in seen_projects:
            _apply_project_config(apiurl, obs_project_name, project_path)
            seen_projects.add(obs_project)

        _apply_package_config(apiurl, obs_project_name, package_path.name, package_path)

        obs_dir = package_path / "obs"
        if obs_dir.is_dir():
            _upload_obs_files(apiurl, obs_project_name, package_path.name, obs_dir)


def cmd_config_apply(args):
    """Apply project/package configuration from yaml files to OBS.

    Supported call forms:
      config apply                        — apply config for the root project
      config apply <project>              — apply config for a specific project
      config apply <project> <package>    — apply config for a specific package under a project
    """
    apiurl = osc.conf.config["apiurl"]

    if args.project is None:
        # No args: apply config for the root project
        project_path = REPO_ROOT
        obs_project = args.rootprj
    else:
        project_path = resolve_project_path(args.project)
        if not project_path.is_dir():
            print(f"error: '{args.project}' not found under root/", file=sys.stderr)
            sys.exit(1)
        if is_package(project_path):
            print(f"error: '{args.project}' is a package, not a project", file=sys.stderr)
            sys.exit(1)
        obs_project = f"{args.rootprj}:{args.project}"

    project_config = load_yaml(project_path / "project.yaml")
    obs_project_name = project_config.get("name") or obs_project

    if args.package is not None:
        package_path = project_path / args.package
        if not package_path.is_dir():
            print(f"error: package directory not found: {package_path}", file=sys.stderr)
            sys.exit(1)
        if not is_package(package_path):
            print(f"error: '{args.package}' is not a package (no obs/ directory found inside)", file=sys.stderr)
            sys.exit(1)
        _apply_package_config(apiurl, obs_project_name, package_path.name, package_path, force=args.force)
    else:
        _apply_project_config(apiurl, obs_project_name, project_path, force=args.force)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="percona-obs",
        description="Manage Percona packages on an OBS instance.",
    )
    parser.add_argument(
        "-A", "--apiurl",
        metavar="URL",
        help="OBS API URL (e.g. http://my-obs-instance.local:8000)",
    )
    parser.add_argument(
        "-R", "--rootprj",
        metavar="PROJECT",
        required=True,
        help="OBS root project under which all projects are deployed (e.g. home:Admin)",
    )

    subparsers = parser.add_subparsers(dest="command", metavar="<command>")
    subparsers.required = True

    deploy_parser = subparsers.add_parser(
        "deploy",
        help="Create or update a project/package on OBS from local packaging files.",
    )
    deploy_parser.add_argument(
        "project",
        nargs="?",
        default=None,
        help="Project name (colon notation, e.g. ppg:17.9) or top-level package name. "
             "If omitted, all packages and projects under root/ are deployed.",
    )
    deploy_parser.add_argument(
        "package",
        nargs="?",
        default=None,
        help="Package name to deploy. If omitted, all packages and subprojects under the project are deployed.",
    )
    deploy_parser.set_defaults(func=cmd_deploy)

    config_parser = subparsers.add_parser(
        "config",
        help="Manage OBS project and package configuration.",
    )
    config_subparsers = config_parser.add_subparsers(dest="config_command", metavar="<subcommand>")
    config_subparsers.required = True

    config_apply_parser = config_subparsers.add_parser(
        "apply",
        help="Apply configuration from project.yaml / package.yaml to OBS.",
    )
    config_apply_parser.add_argument(
        "project",
        nargs="?",
        default=None,
        help="Project name (colon notation, e.g. ppg:17.9). "
             "If omitted, config is applied to all projects under root/.",
    )
    config_apply_parser.add_argument(
        "package",
        nargs="?",
        default=None,
        help="Package name. If given, package.yaml of this package is also applied.",
    )
    config_apply_parser.add_argument(
        "--force",
        action="store_true",
        default=False,
        help="Force update even if OBS reports a conflict.",
    )
    config_apply_parser.set_defaults(func=cmd_config_apply)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    osc.conf.get_config(override_apiurl=args.apiurl)

    args.func(args)


if __name__ == "__main__":
    main()
