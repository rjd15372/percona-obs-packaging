#!/usr/bin/make -f
export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_strip:
override_dh_compress:
override_dh_shlibdeps:
override_dh_dwz:
override_dh_usrlocal:
override_dh_strip_nondeterminism:

override_dh_auto_install:
	mkdir -p debian/golang-1.25/usr/local/go
	find . -maxdepth 1 ! -name debian ! -name . -exec cp -a {} debian/golang-1.25/usr/local/go/ \;
	mkdir -p debian/golang-1.25/usr/bin
	ln -sf /usr/local/go/bin/go debian/golang-1.25/usr/bin/go
	ln -sf /usr/local/go/bin/gofmt debian/golang-1.25/usr/bin/gofmt
